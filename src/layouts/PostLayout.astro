---
import BaseLayout from "./BaseLayout.astro";
import { Authors } from "../data/authors";

interface Props {
    title: string;
    description: string;
    date: Date;
    author?: string;
    image?: { path: string };
    tags?: string[];
    lastModified?: Date;
    entryId?: string;
}

const {
    title,
    description,
    date,
    author = "maxulysse",
    image,
    tags = [],
    lastModified,
    entryId,
} = Astro.props as Props;

// Calculate read time
const content = await Astro.slots.render("default");
const words = content.split(/\s+/).length;
const readTime = Math.ceil(words / 160); // 160 words per minute

const authorInfo = Authors[author as keyof typeof Authors] || Authors.maxulysse;
const modifiedDate = lastModified || date;

const githubBaseUrl = "https://github.com/maxulysse/maxulysse.github.io";
// Use entryId (e.g. "2020/2020-07-01-jobim.md") when available — it includes
// the correct file extension, so .mdx files are handled correctly too.
const editUrl = entryId
    ? `${githubBaseUrl}/edit/main/src/content/blog/${entryId}`
    : githubBaseUrl;
---

<BaseLayout
    title={title}
    description={description}
    author={author}
    image={image}
>
    <div class="card-columns only-one-column">
        <div class="card rounded">
            <div class="card-header">
                <h2 class="card-title">{title}</h2>
                <h6 class="card-subtitle mb-2 text-muted">
                    <span
                        ><i class="fa-solid fa-user" aria-hidden="true"
                        ></i></span
                    >
                    <em>{authorInfo.name}</em>
                    <span
                        ><i class="fa-solid fa-calendar" aria-hidden="true"
                        ></i></span
                    >
                    {
                        date.toLocaleDateString("en-US", {
                            year: "numeric",
                            month: "2-digit",
                            day: "2-digit",
                        })
                    }
                    {
                        lastModified && (
                            <div class="float-end">
                                <span>
                                    Last modified{" "}
                                    <i
                                        class="fa-solid fa-calendar"
                                        aria-hidden="true"
                                    />
                                </span>
                                {modifiedDate.toLocaleDateString("en-US", {
                                    year: "numeric",
                                    month: "2-digit",
                                    day: "2-digit",
                                })}
                            </div>
                        )
                    }
                    <br />
                    <i class="fa-solid fa-clock" aria-hidden="true"></i>
                    {readTime} min read
                </h6>
            </div>
            <div class="card-body">
                <slot />

                {
                    tags && tags.length > 0 && (
                        <div class="tags mt-3">
                            {tags.map((tag) => (
                                <a
                                    href={`/tags/${tag.toLowerCase()}/`}
                                    class="badge badge-primary"
                                >
                                    {tag}
                                </a>
                            ))}
                        </div>
                    )
                }
            </div>
            <div class="card-footer">
                <small class="text-muted"
                    >This site is using <a
                        href="https://github.com/maxulysse/maxulysse.github.io"
                        target="_blank"
                        rel="noopener"><i class="fab fa-github"></i> GitHub</a
                    > for versioning. You can fix this page by suggesting changes
                    <a href={editUrl} target="_blank" rel="noopener">here.</a
                    ></small
                >
            </div>
        </div>
    </div>
</BaseLayout>

<style is:global>
    .card-columns {
        column-count: 1;
    }

    .tags a {
        margin-right: 0.5rem;
        margin-bottom: 0.5rem;
    }
</style>
