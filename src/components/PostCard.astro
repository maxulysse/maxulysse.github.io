---
import type { CollectionEntry } from "astro:content";

interface Props {
    post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
---

<div class="col-md-4 mb-3">
    <div class="card h-100">
        {post.data.image && (
            <div class="card-header p-3">
                <img
                    src={post.data.image.path}
                    class="card-img-top"
                    alt={post.data.title}
                    loading="lazy"
                />
            </div>
        )}
        <div class="card-body">
            <h5 class="card-title">
                <a href={`/blog/${post.id}/`}>{post.data.title}</a>
            </h5>
            <p class="card-text">
                {post.data.description ||
                    post.body?.substring(0, 150) ||
                    ""}
            </p>
        </div>
        <div class="card-footer">
            <small class="text-muted d-block mb-2">
                <i class="fa-regular fa-calendar me-1" aria-hidden="true" />
                {post.data.date.toISOString().split("T")[0]}
            </small>
            {post.data.tags && post.data.tags.length > 0 && (
                <div class="tags-container">
                    <span class="text-muted me-2">
                        <i class="fa-solid fa-tags" aria-hidden="true" />
                    </span>
                    {post.data.tags.map((tag: string, index: number) => (
                        <>
                            <a
                                href={`/tags/${tag.toLowerCase()}/`}
                                class="tag-badge"
                            >
                                {tag}
                            </a>
                            {index < (post.data.tags?.length ?? 0) - 1 && (
                                <span class="tag-separator">•</span>
                            )}
                        </>
                    ))}
                </div>
            )}
        </div>
    </div>
</div>

<style>
    .tags-container {
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem;
    }

    :global(.card-img-top) {
        width: 100%;
        height: 180px;
        object-fit: cover;
    }

    .badge {
        text-decoration: none;
        font-size: 0.75rem;
        padding: 0.35rem 0.65rem;
    }

    .badge:hover {
        opacity: 0.8;
    }
</style>
